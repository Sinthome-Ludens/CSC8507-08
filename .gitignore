################################################################################
# Visual Studio
################################################################################
.vs/
*.vsidx
*.ipch
*.db
*.opendb
*.VC.db
*.VC.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.user

# Visual Studio cache/options directory
.vscode/
.idea/
.claude/
.gemini/
GEMINI.md
docs/
################################################################################
# Build Outputs
################################################################################
Build/
out/
x64/
x86/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/

# Executables
*.exe
*.dll
*.so
*.dylib

# Object files（仅排除编译产物，不影响 Assets 下的 .obj 3D 模型）
*.o
*.lo
*.slo

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lai

# Debug files
*.pdb
*.ilk
*.idb
*.log
*.tlog

################################################################################
# CMake
################################################################################
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
*.dir/
.cmake/

# CMake-generated Visual Studio files
*.sln
*.vcxproj
*.vcxproj.filters

# CMake 编译产生的 .obj 目标文件（按目录排除，避免误杀 Assets 下的 .obj 模型）
cmake-build-*/
CMakeFiles/**/*.obj

################################################################################
# External Libraries (需要手动下载，见 README.md)
################################################################################
External/*
# FMOD Core API 直接提交到仓库（~5MB），队友 clone 后零额外步骤
!External/fmod/
!External/fmod/**
# 覆盖全局 *.dll / *.lib 忽略规则，允许 FMOD 二进制入库
!External/fmod/lib/**/*.dll
!External/fmod/lib/**/*.lib

################################################################################
# Assets — 确保全部内容被追踪
################################################################################
# 强制包含 Assets 目录下的所有文件（覆盖上方的通配符规则）
!Assets/
!Assets/**

################################################################################
# Save Files
################################################################################
Assets/Saves/
*.save

################################################################################
# Temporary Files
################################################################################
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

################################################################################
# Documentation
################################################################################
Docs/
# Keep root README trackable
*.md
!README.md
!Assets/**/*.md
!.github/copilot-instructions.md
!.github/instructions/
!.github/instructions/**/*.instructions.md

################################################################################
# Git Submodule (if needed)
################################################################################
# Uncomment if you want to ignore submodule changes
# NCLCoreClasses/
# CSC8503CoreClasses/
# VulkanRendering/
# OpenGLRendering/
*.bak
imgui.ini
