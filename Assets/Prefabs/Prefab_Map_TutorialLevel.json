{
  "PrefabID": "PREFAB_MAP_TUTORIAL_LEVEL",
  "Name": "Map_TutorialLevel",
  "Description": "TutorialLevel map Prefab (mapScale=2.0). C_D_MapConfig stores all resource paths; MapLoader creates entities at runtime.",
  "Components": {
    "C_D_Transform": {
      "position": [0.0, -12.0, 0.0],
      "rotation": [0.0, 0.0, 0.0, 1.0],
      "scale":    [2.0, 2.0, 2.0]
    },
    "C_D_MeshRenderer": {
      "meshHandle": "TutorialMap.gltf",
      "materialHandle": 0
    },
    "C_D_Material": { "shadingModel": "BlinnPhong" },
    "C_D_RigidBody": { "is_static": true },
    "C_D_Collider": {
      "type": "TriMesh",
      "friction": 0.5, "restitution": 0.0,
      "_note": "triVerts/triIndices populated by MapLoader from collisionMesh"
    },
    "C_D_MapConfig": {
      "renderMesh":         "TutorialMap.obj",
      "collisionMesh":      "TutorialMap_collision.obj",
      "navmesh":            "TutorialMap.navmesh",
      "finishMesh":         "TutorialMap_finish.obj",
      "startPoints":        "TutorialMap.startpoints",
      "enemySpawns":        "TutorialMap.enemyspawns",
      "doorKeys":           "TutorialMap.doors",
      "itemSpawns":         "TutorialMap.itemspawns",
      "mapScale":           2.0,
      "yOffset":            -6.0,
      "flipWinding":        true,

      "renderMeshGltf":     "TutorialMap.gltf",
      "collisionMeshGltf":  "TutorialMap_collision.gltf",
      "finishMeshGltf":     "TutorialMap_finish.gltf"
    },
    "C_D_DebugName": { "name": "ENTITY_Env_StaticMap" }
  }
}
